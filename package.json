{
	"name": "overrule",
	"version": "0.2.0",
	"description": "Catch Tailwind class conflicts in dev and CI, fix them in source, ship none of tailwind-merge.",
	"license": "MIT",
	"author": {
		"name": "Nic Polumeyv",
		"url": "https://github.com/Nic-Polumeyv"
	},
	"repository": "github:Nic-Polumeyv/overrule",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"tailwind",
		"tailwindcss",
		"tailwind-merge",
		"class conflicts",
		"lint",
		"codemod"
	],
	"bin": {
		"overrule": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./test": {
			"types": "./dist/test.d.ts",
			"default": "./dist/test.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"test": "bun test",
		"prepublishOnly": "bun run build && bunx publint"
	},
	"dependencies": {
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/node": "^25.9.3",
		"typescript": "^6.0.3"
	}
}
