{
	"compilerOptions": {
		"target": "es2022",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"strict": true,
		"declaration": true,
		"rootDir": "src",
		"types": ["node"],
		"outDir": "dist",
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["src"]
}
